# Monad Testnet Wallet (required)
PRIVATE_KEY=0x_your_private_key_here

# Monad RPC (optional, defaults to public testnet)
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz/

# BNB Chain Testnet RPC (optional)
BNB_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# Agent Configuration
AGENT_INTERVAL_MS=60000
# Optional chain selection for the autonomous agent
AGENT_CHAIN=monad
# BNB collection to mint into when running on BNB testnet
AGENT_COLLECTION_ID=0

# x402 Micropayments (optional)
# Service address for micropayments (defaults to self)
SERVICE_ADDRESS=0x...
# Payment threshold in smallest units (default: 1000 = $0.001)
PAYMENT_THRESHOLD=1000

# Farcaster Integration (optional)
FARCASTER_MNEMONIC=your twelve word mnemonic here
FARCASTER_HUB=https://hub.pinata.cloud

# Moltbook Integration (optional)
MOLTBOOK_API_KEY=your_moltbook_api_key_here

# Legacy Neynar config (kept for compatibility)
NEYNAR_API_KEY=your_neynar_api_key_here
SIGNER_UUID=your_signer_uuid_here

# OpenAI API Key for AI-powered generation (optional)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
