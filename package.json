{
  "name": "glyphgenesis",
  "version": "2.0.0",
  "description": "AI-powered autonomous art generation and on-chain marketplace for AI agents — chain-agnostic",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "generate": "node ascii-generator.js",
    "deploy": "npx hardhat run scripts/deploy.js --network monadTestnet",
    "mint": "node scripts/mint.js",
    "agent": "node scripts/agent.js",
    "test": "node test/ascii-generator.test.mjs && echo 'Run hardhat test for contract tests'"
  },
  "keywords": [
    "ai-agent",
    "art-generation",
    "glyph",
    "ascii-art",
    "blockchain",
    "agentic-commerce",
    "four-meme"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.0",
    "ethers": "^6.11.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "chai": "^4.3.0"
  }
}